# Copy to .env.local and fill in real values

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

NEXTAUTH_SECRET="<generate with: node -e \"console.log(require('crypto').randomBytes(32).toString('base64'))\">"
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="<same as NEXTAUTH_SECRET>"
AUTH_TRUST_HOST="true"

# Optional: required only for admin image uploads.
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="fixnow-media"
SUPABASE_VERIFICATION_BUCKET="fixnow-verifications"

# Email Configuration — required for account email OTP verification.
# Gmail-style names are supported directly (recommended for quick setup).
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT="587"
SENDER_EMAIL="your-email@gmail.com"
# Gmail App Password (16 chars, no spaces) — NOT your login password.
SENDER_PASSWORD="your-app-password"
# Optional: overrides the default From line ("FixNow <SENDER_EMAIL>").
# SMTP_FROM="FixNow <your-email@gmail.com>"

# Chatbot (Google AI Studio key — aistudio.google.com). Provider reads this name automatically.
GOOGLE_GENERATIVE_AI_API_KEY=""
# Optional, defaults to gemini-3.1-flash-lite
CHATBOT_MODEL=""
